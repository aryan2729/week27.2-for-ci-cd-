{
  "name": "27.2-monorepo-deployment-during-class",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate":"cd packages/db && npx prisma generate && cd ../..",
    "start:web":"cd apps/web && bun run start",
    "start:backend":"cd apps/backend && bun run start",
    "start:websocket":"cd apps/ws && bun run start"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "prisma": "^7.8.0"
  }
}
